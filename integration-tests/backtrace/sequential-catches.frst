# Multiple catch/recover cycles, then crash.
# The final crash trace must only contain frames from the last error.

# Cycle 1: Function_Call
def r1 = try_call(fn x -> x + "a", [1])
assert(r1.ok == false)
assert(1 + 2 == 3)

# Cycle 2: Map
def r2 = try_call(fn -> map [1] with fn x -> x + "b", [])
assert(r2.ok == false)
assert(map [1] with fn x -> x + 1 == [2])

# Cycle 3: Do_Block
def r3 = try_call(fn -> do { 1 + "c" }, [])
assert(r3.ok == false)
assert(do { 10 } == 10)

# Cycle 4: Nested (Map inside Function_Call)
defn map_fail(arr) -> map arr with fn x -> x + "d"
def r4 = try_call(map_fail, [[1]])
assert(r4.ok == false)
assert(map [1] with fn x -> x + 1 == [2])

# Final crash - only these frames in trace
defn last_crash(x) -> x + "end"
last_crash(1)
