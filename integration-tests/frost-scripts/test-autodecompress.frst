def { autodecompress } = import('autodecompress')
def c = import('ext.compression')

def original = "the quick brown fox jumps over the lazy dog"

# Test each available algorithm
def algos = ["gzip", "zstd", "bz2", "xz", "lz4"]
foreach (algos @ select(fn name -> c @has(name))) with fn name -> {
    def compressed = c[name].compress(original)
    assert(autodecompress(compressed) == original,
        $'round-trip failed for ${name}')
}

# Unrecognized input
def result = try_call(autodecompress, ["not compressed"])
assert(not result.ok)
assert(result.error @ contains("unrecognized"))
