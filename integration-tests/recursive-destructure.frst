# Recursive destructuring integration tests

# --- Basic nesting ---

def [a, [b, c]] = [1, [2, 3]]
assert(a == 1)
assert(b == 2)
assert(c == 3)

def {foo: [x, y]} = {foo: [10, 20]}
assert(x == 10)
assert(y == 20)

def [{alpha}, beta] = [{alpha: 'a'}, 'b']
assert(alpha == 'a')
assert(beta == 'b')

def {outer: {inner: val}} = {outer: {inner: 42}}
assert(val == 42)

# --- Deep nesting ---

def [[[deep]]] = [[[99]]]
assert(deep == 99)

# --- Discards in nested patterns ---

def [_, [_, kept]] = [1, [2, 3]]
assert(kept == 3)

def {ignored: _, used: v} = {ignored: 'skip', used: 'keep'}
assert(v == 'keep')

# --- Rest in nested arrays ---

def [head, [first, ...nested_rest]] = [0, [1, 2, 3, 4]]
assert(head == 0)
assert(first == 1)
assert(nested_rest == [2, 3, 4])

def {data: [_, ...rest]} = {data: [10, 20, 30]}
assert(rest == [20, 30])

# --- Empty nested ---

def [ok, []] = [1, []]
assert(ok == 1)

# --- Missing map keys are an error ---
# (Exhaustiveness is not required, but all named keys must be present.)

def {present} = {present: 1, extra: 2}
assert(present == 1)

# --- Interaction with closures and capture analysis ---

# Nested destructure bindings should be captured by closures
def make_adder = fn -> {
    def [base, [scale, offset]] = [10, [2, 5]]
    fn x -> base + scale * x + offset
}
def adder = make_adder()
assert(adder(3) == 21)  # 10 + 2*3 + 5

# Map destructure bindings captured by closures
def make_greeter = fn -> {
    def {greeting, punctuation} = {greeting: 'hello', punctuation: '!'}
    fn name -> greeting + ' ' + name + punctuation
}
assert(make_greeter()('world') == 'hello world!')

# Nested destructure in a closure that captures from outer scope
def outer_val = 100
def make_fn = fn -> {
    def [a, {b}] = [1, {b: 2}]
    fn -> a + b + outer_val
}
assert(make_fn()() == 103)

# Destructure bindings used across multiple closures
def [shared_a, shared_b] = [10, 20]
def fn1 = fn -> shared_a
def fn2 = fn -> shared_b
def fn3 = fn -> shared_a + shared_b
assert(fn1() == 10)
assert(fn2() == 20)
assert(fn3() == 30)

# Recursive function using destructured bindings
defn sum_nested(arr) -> {
    def [head, ...tail] = arr
    if len(tail) == 0: head
    else: head + sum_nested(tail)
}
assert(sum_nested([1, 2, 3, 4]) == 10)

# Destructure inside a do block
def result = do {
    def [a, [b, c]] = [1, [2, 3]]
    a + b + c
}
assert(result == 6)

# Destructure with rest discard
def [kept_val, ..._] = [42, 'ignore', 'these']
assert(kept_val == 42)

# Computed key in map destructure captures free variables in closures
def computed_key = 'foo'
def computed_fn = fn -> {
    def {[computed_key]: val} = {foo: 99}
    val
}
assert(computed_fn() == 99)

# --- Map destructure with `as` (whole-map binding) ---

# Basic: pull out fields and keep the whole map
def {name: as_name, age: as_age} as as_person = {name: 'Alice', age: 30, role: 'admin'}
assert(as_name == 'Alice')
assert(as_age == 30)
assert(as_person == {name: 'Alice', age: 30, role: 'admin'})

# Empty pattern with `as` binds the whole map
def {} as as_whole = {x: 1, y: 2}
assert(as_whole == {x: 1, y: 2})

# Shorthand entries with `as`
def {foo: as_foo} as as_m = {foo: 42, bar: 10}
assert(as_foo == 42)
assert(as_m.bar == 10)

# Nested: map `as` inside array destructure
def [{a: as_a} as as_m1, {b: as_b} as as_m2] = [{a: 1}, {b: 2}]
assert(as_a == 1)
assert(as_b == 2)
assert(as_m1 == {a: 1})
assert(as_m2 == {b: 2})

# Nested: map `as` inside map destructure
def {outer: {inner: as_inner} as as_sub} = {outer: {inner: 42, extra: 99}}
assert(as_inner == 42)
assert(as_sub.extra == 99)

# `as` binding captured by closure
def make_lookup = fn -> {
    def {key: as_k} as as_full = {key: 'found', other: 'also'}
    fn -> as_full.other
}
assert(make_lookup()() == 'also')

# `as` inside a do block
def as_do_result = do {
    def {x: as_x} as as_do_m = {x: 10, y: 20}
    as_x + as_do_m.y
}
assert(as_do_result == 30)
