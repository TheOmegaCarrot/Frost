# Hey, there's almost an idea here!
export defn object(obj) -> map obj with fn k, v -> match v {
        _ is Function => { [k]: fn ...args -> call(v, [obj] + args) },
        _ => { [k]: v }
    }

export def obj = object({
    square: fn this, x ->  this.mul(this, x, x),
    mul: fn this, a, b -> a * b,
    val: 42,
    add_val: fn this, x -> this.val + x,
})
