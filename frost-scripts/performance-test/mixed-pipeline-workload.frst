def input = range(1500000)

def stage1 = map input with fn (x) -> { x * 3 + 1 }
def stage2 = filter stage1 with fn (x) -> { x % 5 == 0 }
def stage3 = map stage2 with fn (x) -> { x + 7 }
def result = reduce stage3 init: 0 with fn (acc, x) -> { acc + x }

assert(result == 675002850000, 'mixed pipeline sum')
print(result)
