# SQLite named bindings tests

def fs = import('std.fs')
def sqlite = import('ext.sqlite')
def path = args[1]

if fs.exists(path): fs.remove(path)

def db = sqlite.open(path)

db.exec('CREATE TABLE t (id INTEGER PRIMARY KEY, name TEXT, score REAL)')

# --- exec with named bindings ---

def n1 = db.exec('INSERT INTO t VALUES (:id, :name, :score)', {id: 1, name: 'alice', score: 9.5})
assert(n1 == 1, 'named insert should return 1')

def n2 = db.exec('INSERT INTO t VALUES (:id, :name, :score)', {id: 2, name: 'bob', score: 7.0})
assert(n2 == 1, 'second named insert should return 1')

# @ prefix
def n3 = db.exec('INSERT INTO t VALUES (@id, @name, @score)', {id: 3, name: 'charlie', score: 8.5})
assert(n3 == 1, '@ prefix should work')

# $ prefix
def n4 = db.exec('INSERT INTO t VALUES ($id, $name, $score)', {id: 4, name: 'diana', score: 6.0})
assert(n4 == 1, '$ prefix should work')

# UPDATE with named bindings
def n5 = db.exec('UPDATE t SET score = :score WHERE id = :id', {score: 10.0, id: 1})
assert(n5 == 1, 'named update should return 1')

# DELETE with named bindings
def n6 = db.exec('DELETE FROM t WHERE id = :id', {id: 4})
assert(n6 == 1, 'named delete should return 1')

# --- query with named bindings ---

def rows = db.query('SELECT * FROM t WHERE score >= :min ORDER BY id', {min: 8.0})
assert(len(rows) == 2, 'named query should return matching rows')
assert(rows[0].id == 1, 'first row is alice (updated to 10.0)')
assert(rows[1].id == 3, 'second row is charlie')

# Multiple named parameters in query
def r2 = db.query('SELECT * FROM t WHERE id > :lo AND id < :hi', {lo: 1, hi: 3})
assert(len(r2) == 1, 'range query should return 1 row')
assert(r2[0].name == 'bob', 'range query returns bob')

# @ prefix in query
def r_at = db.query('SELECT * FROM t WHERE id = @id', {id: 2})
assert(len(r_at) == 1, '@ prefix in query')
assert(r_at[0].name == 'bob', '@ prefix query returns correct row')

# $ prefix in query
def r_dollar = db.query('SELECT * FROM t WHERE id = $id', {id: 3})
assert(len(r_dollar) == 1, '$ prefix in query')
assert(r_dollar[0].name == 'charlie', '$ prefix query returns correct row')

# Named query returning empty result
def r3 = db.query('SELECT * FROM t WHERE name = :name', {name: 'nobody'})
assert(r3 == [], 'no match returns empty array')

# --- each with named bindings ---

# : prefix in each
db.exec('CREATE TABLE each_out (name TEXT)')
db.each('SELECT name FROM t WHERE score >= :min ORDER BY name', {min: 8.0}, fn row -> do {
    db.exec('INSERT INTO each_out VALUES (?)', [row.name])
})
def each_rows = db.query('SELECT name FROM each_out ORDER BY name')
assert(len(each_rows) == 2, 'each with named bindings should visit 2 rows')
assert(each_rows[0].name == 'alice', 'each named bindings first row')
assert(each_rows[1].name == 'charlie', 'each named bindings second row')

# @ prefix in each
db.exec('CREATE TABLE each_at (name TEXT)')
db.each('SELECT name FROM t WHERE id = @id', {id: 2}, fn row -> do {
    db.exec('INSERT INTO each_at VALUES (?)', [row.name])
})
def each_at_rows = db.query('SELECT name FROM each_at')
assert(len(each_at_rows) == 1, '@ prefix in each')
assert(each_at_rows[0].name == 'bob', '@ prefix each returns correct row')

# $ prefix in each
db.exec('CREATE TABLE each_dollar (name TEXT)')
db.each('SELECT name FROM t WHERE id = $id', {id: 3}, fn row -> do {
    db.exec('INSERT INTO each_dollar VALUES (?)', [row.name])
})
def each_dollar_rows = db.query('SELECT name FROM each_dollar')
assert(len(each_dollar_rows) == 1, '$ prefix in each')
assert(each_dollar_rows[0].name == 'charlie', '$ prefix each returns correct row')

# --- collect with named bindings ---

# : prefix in collect
def scores = db.collect('SELECT score FROM t WHERE id <= :max_id ORDER BY id', {max_id: 2}, fn row -> row.score)
assert(scores == [10.0, 7.0], 'collect with named bindings')

# @ prefix in collect
def at_names = db.collect('SELECT name FROM t WHERE id = @id', {id: 2}, fn row -> row.name)
assert(at_names == ['bob'], '@ prefix in collect')

# $ prefix in collect
def dollar_names = db.collect('SELECT name FROM t WHERE id = $id', {id: 3}, fn row -> row.name)
assert(dollar_names == ['charlie'], '$ prefix in collect')

# --- All binding value types ---

db.exec('CREATE TABLE types (i INTEGER, f REAL, s TEXT, b INTEGER, n)')

db.exec('INSERT INTO types VALUES (:i, :f, :s, :b, :n)', {i: 42, f: 3.14, s: 'hello', b: true, n: null})
def tr = db.query('SELECT * FROM types')[0]
assert(tr.i == 42, 'Int binding')
assert(tr.f == 3.14, 'Float binding')
assert(tr.s == 'hello', 'String binding')
assert(tr.b == 1, 'Bool binds as integer')
assert(tr.n == null, 'Null binding')

# --- transaction with named bindings ---

db.transaction(fn tx -> {
    tx.exec('INSERT INTO t VALUES (:id, :name, :score)', {id: 10, name: 'tx_alice', score: 1.0})
    tx.exec('INSERT INTO t VALUES (:id, :name, :score)', {id: 11, name: 'tx_bob', score: 2.0})

    def rows = tx.query('SELECT * FROM t WHERE id >= :min_id ORDER BY id', {min_id: 10})
    assert(len(rows) == 2, 'tx query with named bindings')
    assert(rows[0].name == 'tx_alice', 'tx named query first row')
})

# --- Error paths ---

# Named parameter not in query
def bad_name = try_call(db.exec, ['INSERT INTO t VALUES (:id, :name, :score)', {id: 1, name: 'x', wrong: 2.0}])
assert(not bad_name.ok, 'unmatched parameter name should fail')
assert(bad_name.error @ contains('wrong'), 'should mention the bad parameter name')

# Too few named bindings
def too_few = try_call(db.exec, ['INSERT INTO t VALUES (:id, :name, :score)', {id: 1}])
assert(not too_few.ok, 'too few named bindings should fail')
assert(too_few.error @ contains('expected 3'), 'should mention expected count')

# Too many named bindings
def too_many = try_call(db.exec, ['SELECT :x', {x: 1, y: 2}])
assert(not too_many.ok, 'too many named bindings should fail')
assert(too_many.error @ contains('expected 1'), 'should mention expected count')

# Named bindings with positional (?) parameters
def mixed = try_call(db.exec, ['SELECT ?', {x: 1}])
assert(not mixed.ok, 'named bindings with positional params should fail')
assert(mixed.error @ contains('positional'), 'should mention positional')

# Unsupported binding type in named map
def bad_type = try_call(db.exec, ['SELECT :x', {x: [1, 2]}])
assert(not bad_type.ok, 'Array value in named binding should fail')
assert(bad_type.error @ contains('unsupported binding type'), 'should mention unsupported type')

# Non-string key in binding map (Int key)
def int_key = try_call(db.exec, ['SELECT :x', {[1]: 'hello'}])
assert(not int_key.ok, 'non-string key should fail')

# Empty named bindings when query expects parameters
def empty_map = try_call(db.exec, ['SELECT :x', {}])
assert(not empty_map.ok, 'empty map when expecting bindings should fail')

# Connection still usable after errors
def recovery = db.query('SELECT count(*) as c FROM t')
assert(recovery[0].c > 0, 'connection usable after named binding errors')

# Clean up
db.close()
if path != ':memory:': fs.remove(path)
