# Verify zipfile virtual table extension is enabled

def fs = import('std.fs')
def sqlite = import('ext.sqlite')
def path = args[1]

if fs.exists(path): fs.remove(path)

def db = sqlite.open(path)

# Create a zip blob via the zipfile() aggregate function
def zip_blob = db.query('''
    SELECT zipfile(name, data) as z
    FROM (
        SELECT 'hello.txt' as name, 'hello world' as data
        UNION ALL
        SELECT 'bye.txt', 'goodbye'
    )
    ''')[0].z

assert(is_string(zip_blob), 'zipfile() should produce a blob')
assert(len(zip_blob) > 0, 'zip blob should not be empty')

# Write the zip to a temp file and read it back via zipfile() table-valued function
def zip_path = path + '.test.zip'
if fs.exists(zip_path): fs.remove(zip_path)
db.exec('SELECT writefile(?, ?)', [zip_path, zip_blob])

def entries = db.query('SELECT name, data FROM zipfile(?)', [zip_path])
assert(len(entries) == 2, 'zip should contain two files')

def names = transform(entries, fn r -> r.name)
assert(names @ includes('hello.txt'))
assert(names @ includes('bye.txt'))

fs.remove(zip_path)
db.close()
if path != ':memory:': fs.remove(path)
