# Verify foreign key enforcement is on by default

def fs = import('std.fs')
def sqlite = import('ext.sqlite')
def path = args[1]

if fs.exists(path): fs.remove(path)

def db = sqlite.open(path)

db.exec('CREATE TABLE parent (id INTEGER PRIMARY KEY)')
db.exec('CREATE TABLE child (pid REFERENCES parent(id))')
db.exec('INSERT INTO parent VALUES (1)')

# Valid FK
db.exec('INSERT INTO child VALUES (1)')

# Invalid FK
def bad = try_call(fn -> db.exec('INSERT INTO child VALUES (999)'))
assert(not bad.ok, 'FK violation should error')
assert(contains(bad.error, 'FOREIGN KEY'), 'error should mention FK')

db.close()
if path != ':memory:': fs.remove(path)
