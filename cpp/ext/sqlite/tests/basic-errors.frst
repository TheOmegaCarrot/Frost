# SQLite error handling
# Verifies that SQLite errors surface as recoverable Frost errors
# and do not corrupt connection state.

def path = args[1]

# Open failure - nonexistent directory
def bad_open = try_call(sqlite.open, ['/no/such/dir/test.db'])
assert(not bad_open.ok, 'open with bad path should fail')

# Wrong argument type
if fs.exists(path): fs.remove(path)
def db = sqlite.open(path)
def wrong_type = try_call(db.exec, [123])
assert(not wrong_type.ok, 'execute with non-string should fail')
db.exec('CREATE TABLE t (id INTEGER PRIMARY KEY, name TEXT)')
db.exec("INSERT INTO t VALUES (1, 'alice')")

# Duplicate primary key
def dup = try_call(db.exec, ["INSERT INTO t VALUES (1, 'duplicate')"])
assert(not dup.ok, 'duplicate primary key should fail')

# Invalid SQL
def bad_sql = try_call(db.exec, ['NOT VALID SQL'])
assert(not bad_sql.ok, 'invalid SQL should fail')

# Missing table
def no_table = try_call(db.exec, ['INSERT INTO nonexistent VALUES (1)'])
assert(not no_table.ok, 'missing table should fail')

# Trailing content (multi-statement)
def trailing = try_call(db.exec, ["INSERT INTO t VALUES (2, 'bob'); INSERT INTO t VALUES (3, 'charlie')"])
assert(not trailing.ok, 'multi-statement exec should fail')
assert(contains(trailing.error, 'trailing content'), 'should mention trailing content')

# Unsupported binding type
def bad_bind = try_call(db.exec, ['INSERT INTO t VALUES (?, ?)', [[1, 2], 'x']])
assert(not bad_bind.ok, 'Array binding should fail')
assert(contains(bad_bind.error, 'unsupported binding type'), 'should mention unsupported type')

# Connection should still be usable after errors
def n = db.exec('INSERT INTO t VALUES (?, ?)', [2, 'bob'])
assert(n == 1, 'insert after errors should succeed')

# Double close
db.close()
def close2 = try_call(db.close, [])
assert(not close2.ok, 'double close should fail')

# Clean up filesystem db
if path != ':memory:': fs.remove(path)
