# SQLite db.query error handling
# Verifies that query errors surface as recoverable Frost errors
# and do not corrupt connection state.

def path = args[1]

if fs.exists(path): fs.remove(path)

def db = sqlite.open(path)
db.exec('CREATE TABLE t (id INTEGER PRIMARY KEY, name TEXT)')
db.exec("INSERT INTO t VALUES (1, 'alice')")

# Invalid SQL
def bad_sql = try_call(db.query, ['NOT VALID'])
assert(not bad_sql.ok, 'invalid SQL should fail')

# Too few bindings
def too_few = try_call(db.query, ['SELECT ? + ?', [1]])
assert(not too_few.ok, 'too few bindings should fail')
assert(contains(too_few.error, 'expected 2'), 'should mention expected count')

# Too many bindings
def too_many = try_call(db.query, ['SELECT ?', [1, 2, 3]])
assert(not too_many.ok, 'too many bindings should fail')
assert(contains(too_many.error, 'expected 1'), 'should mention expected count')

# Zero bindings when expecting some (no bindings argument)
def zero_bindings = try_call(db.query, ['SELECT ?'])
assert(not zero_bindings.ok, 'zero bindings when expecting some should fail')
assert(contains(zero_bindings.error, 'expected 1'), 'should mention expected count')

# Unsupported binding type: Array
def bad_arr = try_call(db.query, ['SELECT ?', [[1, 2]]])
assert(not bad_arr.ok, 'Array binding should fail')
assert(contains(bad_arr.error, 'unsupported binding type'), 'should mention unsupported type')

# Unsupported binding type: Map
def bad_map = try_call(db.query, ['SELECT ?', [{a: 1}]])
assert(not bad_map.ok, 'Map binding should fail')
assert(contains(bad_map.error, 'unsupported binding type'), 'should mention unsupported type')

# Trailing content (multi-statement)
def trailing = try_call(db.query, ['SELECT 1; SELECT 2'])
assert(not trailing.ok, 'trailing content should fail')
assert(contains(trailing.error, 'trailing content'), 'should mention trailing content')

# Wrong argument type for SQL parameter
def wrong_type = try_call(db.query, [123])
assert(not wrong_type.ok, 'non-string SQL should fail')

# --- each error paths ---

def each_bad_sql = try_call(db.each, [123, fn row -> null])
assert(not each_bad_sql.ok, 'each: non-string SQL should fail')

def each_invalid = try_call(db.each, ['NOT VALID', fn row -> null])
assert(not each_invalid.ok, 'each: invalid SQL should fail')

def each_trailing = try_call(db.each, ['SELECT 1; SELECT 2', fn row -> null])
assert(not each_trailing.ok, 'each: trailing content should fail')
assert(contains(each_trailing.error, 'trailing content'), 'each: should mention trailing content')

def each_too_few = try_call(db.each, ['SELECT ? + ?', [1], fn row -> null])
assert(not each_too_few.ok, 'each: too few bindings should fail')

def each_too_many = try_call(db.each, ['SELECT ?', [1, 2, 3], fn row -> null])
assert(not each_too_many.ok, 'each: too many bindings should fail')

def each_zero = try_call(db.each, ['SELECT ?', fn row -> null])
assert(not each_zero.ok, 'each: zero bindings when expecting some should fail')

def each_bad_bind_arr = try_call(db.each, ['SELECT ?', [[1, 2]], fn row -> null])
assert(not each_bad_bind_arr.ok, 'each: Array binding should fail')

def each_bad_bind_map = try_call(db.each, ['SELECT ?', [{a: 1}], fn row -> null])
assert(not each_bad_bind_map.ok, 'each: Map binding should fail')

def each_bad_bind_fn = try_call(db.each, ['SELECT ?', [fn x -> x], fn row -> null])
assert(not each_bad_bind_fn.ok, 'each: Function binding should fail')

def each_empty_sql = try_call(db.each, ['', fn row -> null])
assert(not each_empty_sql.ok, 'each: empty SQL should fail')
assert(contains(each_empty_sql.error, 'empty SQL'), 'each: should mention empty SQL')

def each_no_fn = try_call(db.each, ['SELECT 1', 'not a function'])
assert(not each_no_fn.ok, 'each: non-function callback should fail')

def each_throw = try_call(db.each, ['SELECT * FROM t', fn row -> assert(false, 'boom')])
assert(not each_throw.ok, 'each: callback error should propagate')
assert(contains(each_throw.error, 'boom'), 'each: should contain callback error message')

# --- collect error paths ---

def collect_bad_sql = try_call(db.collect, [123, fn row -> null])
assert(not collect_bad_sql.ok, 'collect: non-string SQL should fail')

def collect_invalid = try_call(db.collect, ['NOT VALID', fn row -> null])
assert(not collect_invalid.ok, 'collect: invalid SQL should fail')

def collect_trailing = try_call(db.collect, ['SELECT 1; SELECT 2', fn row -> null])
assert(not collect_trailing.ok, 'collect: trailing content should fail')
assert(contains(collect_trailing.error, 'trailing content'), 'collect: should mention trailing content')

def collect_too_few = try_call(db.collect, ['SELECT ? + ?', [1], fn row -> null])
assert(not collect_too_few.ok, 'collect: too few bindings should fail')

def collect_too_many = try_call(db.collect, ['SELECT ?', [1, 2, 3], fn row -> null])
assert(not collect_too_many.ok, 'collect: too many bindings should fail')

def collect_zero = try_call(db.collect, ['SELECT ?', fn row -> null])
assert(not collect_zero.ok, 'collect: zero bindings when expecting some should fail')

def collect_bad_bind_arr = try_call(db.collect, ['SELECT ?', [[1, 2]], fn row -> null])
assert(not collect_bad_bind_arr.ok, 'collect: Array binding should fail')

def collect_bad_bind_map = try_call(db.collect, ['SELECT ?', [{a: 1}], fn row -> null])
assert(not collect_bad_bind_map.ok, 'collect: Map binding should fail')

def collect_bad_bind_fn = try_call(db.collect, ['SELECT ?', [fn x -> x], fn row -> null])
assert(not collect_bad_bind_fn.ok, 'collect: Function binding should fail')

def collect_empty_sql = try_call(db.collect, ['', fn row -> null])
assert(not collect_empty_sql.ok, 'collect: empty SQL should fail')
assert(contains(collect_empty_sql.error, 'empty SQL'), 'collect: should mention empty SQL')

def collect_no_fn = try_call(db.collect, ['SELECT 1', 'not a function'])
assert(not collect_no_fn.ok, 'collect: non-function callback should fail')

def collect_throw = try_call(db.collect, ['SELECT * FROM t', fn row -> assert(false, 'kaboom')])
assert(not collect_throw.ok, 'collect: callback error should propagate')
assert(contains(collect_throw.error, 'kaboom'), 'collect: should contain callback error message')

# --- exec missing error paths ---

def exec_zero = try_call(db.exec, ['SELECT ?'])
assert(not exec_zero.ok, 'exec: zero bindings when expecting some should fail')

def exec_bad_bind_map = try_call(db.exec, ['SELECT ?', [{a: 1}]])
assert(not exec_bad_bind_map.ok, 'exec: Map binding should fail')

def exec_bad_bind_fn = try_call(db.exec, ['SELECT ?', [fn x -> x]])
assert(not exec_bad_bind_fn.ok, 'exec: Function binding should fail')

def exec_empty_sql = try_call(db.exec, [''])
assert(not exec_empty_sql.ok, 'exec: empty SQL should fail')
assert(contains(exec_empty_sql.error, 'empty SQL'), 'exec: should mention empty SQL')

# --- query missing error paths ---

def query_bad_bind_fn = try_call(db.query, ['SELECT ?', [fn x -> x]])
assert(not query_bad_bind_fn.ok, 'query: Function binding should fail')

# Connection still usable after all errors
def rows = db.query('SELECT * FROM t')
assert(len(rows) == 1, 'query should succeed after errors')

# Closed connection errors for all methods
db.close()

def closed_query = try_call(db.query, ['SELECT 1'])
assert(not closed_query.ok, 'query on closed db should fail')
assert(contains(closed_query.error, 'closed'), 'should mention closed')

def closed_exec = try_call(db.exec, ['SELECT 1'])
assert(not closed_exec.ok, 'exec on closed db should fail')
assert(contains(closed_exec.error, 'closed'), 'should mention closed')

def closed_each = try_call(db.each, ['SELECT 1', fn row -> null])
assert(not closed_each.ok, 'each on closed db should fail')
assert(contains(closed_each.error, 'closed'), 'should mention closed')

def closed_collect = try_call(db.collect, ['SELECT 1', fn row -> null])
assert(not closed_collect.ok, 'collect on closed db should fail')
assert(contains(closed_collect.error, 'closed'), 'should mention closed')

# Clean up filesystem db
if path != ':memory:': fs.remove(path)
