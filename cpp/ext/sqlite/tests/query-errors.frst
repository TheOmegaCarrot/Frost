# SQLite db.query error handling
# Verifies that query errors surface as recoverable Frost errors
# and do not corrupt connection state.

def path = args[1]

if fs.exists(path): fs.remove(path)

def db = sqlite.open(path)
db.exec('CREATE TABLE t (id INTEGER PRIMARY KEY, name TEXT)')
db.exec("INSERT INTO t VALUES (1, 'alice')")

# Invalid SQL
def bad_sql = try_call(db.query, ['NOT VALID'])
assert(not bad_sql.ok, 'invalid SQL should fail')

# Too few bindings
def too_few = try_call(db.query, ['SELECT ? + ?', [1]])
assert(not too_few.ok, 'too few bindings should fail')
assert(contains(too_few.error, 'expected 2'), 'should mention expected count')

# Too many bindings
def too_many = try_call(db.query, ['SELECT ?', [1, 2, 3]])
assert(not too_many.ok, 'too many bindings should fail')
assert(contains(too_many.error, 'expected 1'), 'should mention expected count')

# Zero bindings when expecting some (no bindings argument)
def zero_bindings = try_call(db.query, ['SELECT ?'])
assert(not zero_bindings.ok, 'zero bindings when expecting some should fail')
assert(contains(zero_bindings.error, 'expected 1'), 'should mention expected count')

# Unsupported binding type: Array
def bad_arr = try_call(db.query, ['SELECT ?', [[1, 2]]])
assert(not bad_arr.ok, 'Array binding should fail')
assert(contains(bad_arr.error, 'unsupported binding type'), 'should mention unsupported type')

# Unsupported binding type: Map
def bad_map = try_call(db.query, ['SELECT ?', [{a: 1}]])
assert(not bad_map.ok, 'Map binding should fail')
assert(contains(bad_map.error, 'unsupported binding type'), 'should mention unsupported type')

# Trailing content (multi-statement)
def trailing = try_call(db.query, ['SELECT 1; SELECT 2'])
assert(not trailing.ok, 'trailing content should fail')
assert(contains(trailing.error, 'trailing content'), 'should mention trailing content')

# Wrong argument type for SQL parameter
def wrong_type = try_call(db.query, [123])
assert(not wrong_type.ok, 'non-string SQL should fail')

# --- each error paths ---

# each with invalid SQL
def each_bad = try_call(db.each, ['NOT VALID', fn row -> null])
assert(not each_bad.ok, 'each with invalid SQL should fail')

# each with wrong binding count
def each_binds = try_call(db.each, ['SELECT ? + ?', [1], fn row -> null])
assert(not each_binds.ok, 'each with wrong binding count should fail')

# each with wrong callback type
def each_no_fn = try_call(db.each, ['SELECT 1', 'not a function'])
assert(not each_no_fn.ok, 'each with non-function callback should fail')

# each with wrong SQL type
def each_bad_sql = try_call(db.each, [123, fn row -> null])
assert(not each_bad_sql.ok, 'each with non-string SQL should fail')

# --- collect error paths ---

# collect with invalid SQL
def collect_bad = try_call(db.collect, ['NOT VALID', fn row -> null])
assert(not collect_bad.ok, 'collect with invalid SQL should fail')

# collect with wrong binding count
def collect_binds = try_call(db.collect, ['SELECT ? + ?', [1], fn row -> null])
assert(not collect_binds.ok, 'collect with wrong binding count should fail')

# collect with wrong callback type
def collect_no_fn = try_call(db.collect, ['SELECT 1', 'not a function'])
assert(not collect_no_fn.ok, 'collect with non-function callback should fail')

# --- callback error propagation ---

# each callback that throws
def each_throw = try_call(db.each, ['SELECT * FROM t', fn row -> assert(false, 'boom')])
assert(not each_throw.ok, 'each callback error should propagate')
assert(contains(each_throw.error, 'boom'), 'should contain callback error message')

# collect callback that throws
def collect_throw = try_call(db.collect, ['SELECT * FROM t', fn row -> assert(false, 'kaboom')])
assert(not collect_throw.ok, 'collect callback error should propagate')
assert(contains(collect_throw.error, 'kaboom'), 'should contain callback error message')

# --- SQL edge cases ---

# Empty SQL string
def empty_sql = try_call(db.query, [''])
assert(not empty_sql.ok, 'empty SQL should fail')
assert(contains(empty_sql.error, 'empty SQL'), 'should mention empty SQL')

# Whitespace-only SQL
def ws_sql = try_call(db.query, ['   '])
assert(not ws_sql.ok, 'whitespace-only SQL should fail')
assert(contains(ws_sql.error, 'empty SQL'), 'should mention empty SQL')

# Connection still usable after all errors
def rows = db.query('SELECT * FROM t')
assert(len(rows) == 1, 'query should succeed after errors')

# Closed connection errors for all methods
db.close()

def closed_query = try_call(db.query, ['SELECT 1'])
assert(not closed_query.ok, 'query on closed db should fail')
assert(contains(closed_query.error, 'closed'), 'should mention closed')

def closed_exec = try_call(db.exec, ['SELECT 1'])
assert(not closed_exec.ok, 'exec on closed db should fail')
assert(contains(closed_exec.error, 'closed'), 'should mention closed')

def closed_each = try_call(db.each, ['SELECT 1', fn row -> null])
assert(not closed_each.ok, 'each on closed db should fail')
assert(contains(closed_each.error, 'closed'), 'should mention closed')

def closed_collect = try_call(db.collect, ['SELECT 1', fn row -> null])
assert(not closed_collect.ok, 'collect on closed db should fail')
assert(contains(closed_collect.error, 'closed'), 'should mention closed')

# Clean up filesystem db
if path != ':memory:': fs.remove(path)
