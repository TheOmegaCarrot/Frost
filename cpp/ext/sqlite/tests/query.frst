# SQLite db.query tests

def path = args[1]

if fs.exists(path): fs.remove(path)

def db = sqlite.open(path)

# --- Return path: all 5 SQLite column types ---

db.exec('CREATE TABLE types (i INTEGER, f REAL, t TEXT, b BLOB, n)')
db.exec("INSERT INTO types VALUES (42, 3.14, 'hello', X'DEADBEEF', NULL)")

def rows = db.query('SELECT * FROM types')
assert(len(rows) == 1, 'should return one row')

def row = rows[0]
assert(row.i == 42, 'INTEGER column')
assert(type(row.i) == 'Int', 'INTEGER maps to Int')

assert(row.f == 3.14, 'REAL column')
assert(type(row.f) == 'Float', 'REAL maps to Float')

assert(row.t == 'hello', 'TEXT column')
assert(type(row.t) == 'String', 'TEXT maps to String')

assert(type(row.b) == 'String', 'BLOB maps to String')

assert(row.n == null, 'NULL column')
assert(type(row.n) == 'Null', 'NULL maps to Null')

# --- Binding path: all supported Frost types ---

# Int binding
def r_int = db.query('SELECT * FROM types WHERE i = ?', [42])
assert(len(r_int) == 1, 'Int binding should match')

# Float binding
def r_float = db.query('SELECT * FROM types WHERE f = ?', [3.14])
assert(len(r_float) == 1, 'Float binding should match')

# String binding
def r_str = db.query('SELECT * FROM types WHERE t = ?', ['hello'])
assert(len(r_str) == 1, 'String binding should match')

# Bool binding (binds as integer 1)
db.exec('CREATE TABLE bools (b INTEGER)')
db.exec('INSERT INTO bools VALUES (1)')
def r_bool = db.query('SELECT * FROM bools WHERE b = ?', [true])
assert(len(r_bool) == 1, 'Bool binding should match (binds as 1)')

# Bool false binds as 0
db.exec('INSERT INTO bools VALUES (0)')
def r_false = db.query('SELECT * FROM bools WHERE b = ?', [false])
assert(len(r_false) == 1, 'Bool false binding should match 0')

# Null binding
def r_null = db.query('SELECT * FROM types WHERE n IS ?', [null])
assert(len(r_null) == 1, 'Null binding with IS should match')

# --- Binding edge cases ---

# Empty string binding (distinct from null)
db.exec('CREATE TABLE strs (s TEXT)')
db.exec('INSERT INTO strs VALUES (?)', [''])
db.exec('INSERT INTO strs VALUES (?)', [null])
def r_empty_str = db.query('SELECT * FROM strs WHERE s = ?', [''])
assert(len(r_empty_str) == 1, 'empty string binding should match')
assert(r_empty_str[0].s == '', 'empty string round-trips')
assert(type(r_empty_str[0].s) == 'String', 'empty string is String not Null')

# Explicit empty bindings array
def r_no_params = db.query('SELECT 1 as x', [])
assert(len(r_no_params) == 1, 'empty bindings array should work')

# --- Type round-tripping via exec bindings + query ---

db.exec('CREATE TABLE roundtrip (i INTEGER, f REAL, t TEXT, n)')
db.exec('INSERT INTO roundtrip VALUES (?, ?, ?, ?)', [42, 3.14, 'hello', null])
def rt = db.query('SELECT * FROM roundtrip')[0]
assert(rt.i == 42, 'Int round-trips')
assert(type(rt.i) == 'Int', 'Int type preserved')
assert(rt.f == 3.14, 'Float round-trips')
assert(type(rt.f) == 'Float', 'Float type preserved')
assert(rt.t == 'hello', 'String round-trips')
assert(type(rt.t) == 'String', 'String type preserved')
assert(rt.n == null, 'Null round-trips')
assert(type(rt.n) == 'Null', 'Null type preserved')

# Negative integers
db.exec('CREATE TABLE negatives (v INTEGER)')
db.exec('INSERT INTO negatives VALUES (?)', [-999])
def r_neg = db.query('SELECT * FROM negatives')[0]
assert(r_neg.v == -999, 'negative Int round-trips')

# Zero as Int and Float
db.exec('CREATE TABLE zeros (i INTEGER, f REAL)')
db.exec('INSERT INTO zeros VALUES (?, ?)', [0, 0.0])
def r_zero = db.query('SELECT * FROM zeros')[0]
assert(r_zero.i == 0, 'zero Int round-trips')
assert(type(r_zero.i) == 'Int', 'zero is Int not Null')
assert(r_zero.f == 0.0, 'zero Float round-trips')
assert(type(r_zero.f) == 'Float', 'zero Float type preserved')

# Large integers near INT64 boundaries
db.exec('CREATE TABLE big_ints (v INTEGER)')
db.exec('INSERT INTO big_ints VALUES (?)', [9223372036854775807])
db.exec('INSERT INTO big_ints VALUES (?)', [-9223372036854775807])
def r_big = db.query('SELECT * FROM big_ints ORDER BY v')
assert(r_big[0].v == -9223372036854775807, 'large negative Int round-trips')
assert(r_big[1].v == 9223372036854775807, 'large positive Int round-trips')

# --- Additional query cases ---

# Simple query without bindings
def all_rows = db.query('SELECT * FROM types')
assert(type(all_rows) == 'Array', 'query returns an Array')
assert(len(all_rows) == 1, 'query returns all rows')

# Multiple bindings
def r_multi = db.query('SELECT * FROM types WHERE i > ? AND t LIKE ?', [0, '%ell%'])
assert(len(r_multi) == 1, 'multiple bindings should match')

# Empty result set
def r_empty = db.query('SELECT * FROM types WHERE i = ?', [999])
assert(r_empty == [], 'no match returns empty array')

# Multiple rows returned in order
db.exec('CREATE TABLE multi (id INTEGER, val TEXT)')
db.exec('INSERT INTO multi VALUES (?, ?)', [1, 'first'])
db.exec('INSERT INTO multi VALUES (?, ?)', [2, 'second'])
db.exec('INSERT INTO multi VALUES (?, ?)', [3, 'third'])
def r_multi_rows = db.query('SELECT * FROM multi ORDER BY id')
assert(len(r_multi_rows) == 3, 'should return all rows')
assert(r_multi_rows[0].val == 'first', 'first row correct')
assert(r_multi_rows[1].val == 'second', 'second row correct')
assert(r_multi_rows[2].val == 'third', 'third row correct')

# Trailing semicolon is accepted
def r_semi = db.query('SELECT 1 as x;')
assert(len(r_semi) == 1, 'trailing semicolon should be accepted')

# --- Duplicate column names ---

# When multiple columns share a name, last column wins (insert_or_assign)
db.exec('CREATE TABLE dup_cols (x INTEGER, y INTEGER)')
db.exec('INSERT INTO dup_cols VALUES (1, 2)')
def dup = db.query('SELECT x, y, x + y AS x FROM dup_cols')[0]
assert(len(keys(dup)) == 2, 'duplicate column names collapse into one key')
assert(dup.x == 3, 'last column with duplicate name wins')
assert(dup.y == 2, 'non-duplicate column preserved')

# --- Error paths ---

# No arguments
def query_no_args = try_call(db.query, [])
assert(not query_no_args.ok, 'query with no args should fail')

# Invalid SQL
def bad_sql = try_call(db.query, ['NOT VALID'])
assert(not bad_sql.ok, 'invalid SQL should fail')

# Wrong argument type for SQL parameter
def wrong_type = try_call(db.query, [123])
assert(not wrong_type.ok, 'non-string SQL should fail')

# Too few bindings
def too_few = try_call(db.query, ['SELECT ? + ?', [1]])
assert(not too_few.ok, 'too few bindings should fail')
assert(too_few.error @ contains('expected 2'), 'should mention expected count')

# Too many bindings
def too_many = try_call(db.query, ['SELECT ?', [1, 2, 3]])
assert(not too_many.ok, 'too many bindings should fail')
assert(too_many.error @ contains('expected 1'), 'should mention expected count')

# Zero bindings when expecting some (no bindings argument)
def zero_bindings = try_call(db.query, ['SELECT ?'])
assert(not zero_bindings.ok, 'zero bindings when expecting some should fail')
assert(zero_bindings.error @ contains('expected 1'), 'should mention expected count')

# Unsupported binding type: Array
def bad_arr = try_call(db.query, ['SELECT ?', [[1, 2]]])
assert(not bad_arr.ok, 'Array binding should fail')
assert(bad_arr.error @ contains('unsupported binding type'), 'should mention unsupported type')

# Unsupported binding type: Map
def bad_map = try_call(db.query, ['SELECT ?', [{a: 1}]])
assert(not bad_map.ok, 'Map binding should fail')
assert(bad_map.error @ contains('unsupported binding type'), 'should mention unsupported type')

# Unsupported binding type: Function
def bad_fn = try_call(db.query, ['SELECT ?', [fn x -> x]])
assert(not bad_fn.ok, 'query: Function binding should fail')

# Trailing content (multi-statement)
def trailing = try_call(db.query, ['SELECT 1; SELECT 2'])
assert(not trailing.ok, 'trailing content should fail')
assert(trailing.error @ contains('trailing content'), 'should mention trailing content')

# Empty SQL
def empty_sql = try_call(db.query, [''])
assert(not empty_sql.ok, 'empty SQL should fail')
assert(empty_sql.error @ contains('empty SQL'), 'should mention empty SQL')

# Connection still usable after errors
def recovery = db.query('SELECT * FROM types')
assert(len(recovery) == 1, 'query should succeed after errors')

# Clean up
db.close()
if path != ':memory:': fs.remove(path)
