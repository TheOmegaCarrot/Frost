# Verify SQLite math functions are enabled

def fs = import('std.fs')
def sqlite = import('ext.sqlite')
def path = args[1]

if fs.exists(path): fs.remove(path)

def db = sqlite.open(path)

def rows = db.query('SELECT pi() as pi, abs(-5) as a, sign(-3) as s', [])
assert(len(rows) == 1, 'should return one row')
assert(rows[0].pi > 3.14)
assert(rows[0].pi < 3.15)
assert(rows[0].a == 5)
assert(rows[0].s == -1)

db.close()
if path != ':memory:': fs.remove(path)
