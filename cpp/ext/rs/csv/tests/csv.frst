def csv = import("ext.csv")

# ---- read_str with headers ----

def people = csv.read_str("name,age,city\nAlice,30,NYC\nBob,25,LA", {headers: true})
assert(len(people) == 2)
assert(people[0].name == "Alice")
assert(people[0].age == "30")
assert(people[0].city == "NYC")
assert(people[1].name == "Bob")
assert(people[1].age == "25")
assert(people[1].city == "LA")

# ---- read_str without headers ----

def rows = csv.read_str("a,b,c\n1,2,3", {headers: false})
assert(len(rows) == 2)
assert(rows[0] == ["a", "b", "c"])
assert(rows[1] == ["1", "2", "3"])

# ---- custom delimiter ----

def tsv = csv.read_str("x\ty\tz\n1\t2\t3", {headers: true, delim: "\t"})
assert(len(tsv) == 1)
assert(tsv[0].x == "1")
assert(tsv[0].y == "2")
assert(tsv[0].z == "3")

# ---- callback mode (each/map) ----

def results = csv.read_str("val\n10\n20\n30", {headers: true}, fn row -> row.val)
assert(results == ["10", "20", "30"])

# ---- callback with accumulation ----

def sum = reduce [0] + results with fn (acc, v) -> acc + to_int(v)
assert(sum == 60)

# ---- empty CSV ----

def empty = csv.read_str("name,age", {headers: true})
assert(len(empty) == 0)

def empty_no_header = csv.read_str("", {headers: false})
assert(len(empty_no_header) == 0)

# ---- single row ----

def single = csv.read_str("k,v\nhello,world", {headers: true})
assert(len(single) == 1)
assert(single[0].k == "hello")
assert(single[0].v == "world")

# ---- read_file ----

def io = import("std.io")
def test_path = "./frost_csv_test.csv"
io.write(test_path, "name,age\nAlice,30\nBob,25\n")
def from_file = csv.read_file(test_path, {headers: true})
assert(len(from_file) == 2)
assert(from_file[0].name == "Alice")
assert(from_file[1].age == "25")

# ---- error: missing required 'headers' option ----

def no_headers = try_call(fn -> csv.read_str("a,b\n1,2", {}))
assert(no_headers.ok == false)
assert(contains(no_headers.error, "headers"))

# ---- error: bad option ----

def bad_opt = try_call(fn -> csv.read_str("a,b", {headers: true, bogus: 1}))
assert(bad_opt.ok == false)
assert(contains(bad_opt.error, "unknown option"))

# ---- error: file not found ----

def no_file = try_call(fn -> csv.read_file("/nonexistent/path.csv", {headers: true}))
assert(no_file.ok == false)

# ============================================
# Writing CSV
# ============================================

# ---- write_str: basic array rows ----

def w = csv.write_str({headers: ["name", "age"]})
w.row(["Alice", "30"])
w.row(["Bob", "25"])
assert(w.get() == "name,age\nAlice,30\nBob,25\n")

# ---- write_str: map rows (ordered by headers) ----

def wm = csv.write_str({headers: ["x", "y", "z"]})
wm.row({z: "3", x: "1", y: "2"})
assert(wm.get() == "x,y,z\n1,2,3\n")

# ---- write_str: no headers ----

def wnh = csv.write_str()
wnh.row(["a", "b", "c"])
wnh.row(["1", "2", "3"])
assert(wnh.get() == "a,b,c\n1,2,3\n")

# ---- write_str: custom delimiter ----

def wt = csv.write_str({headers: ["a", "b"], delim: "\t"})
wt.row(["1", "2"])
assert(wt.get() == "a\tb\n1\t2\n")

# ---- write_str: non-string primitives are stringified ----

def wp = csv.write_str({headers: ["val"]})
wp.row([42])
wp.row([true])
wp.row([3.14])
assert(wp.get() == "val\n42\ntrue\n3.14\n")

# ---- write_str: multiple get() calls (writer remains valid) ----

def wg = csv.write_str({headers: ["n"]})
wg.row(["1"])
def snap1 = wg.get()
wg.row(["2"])
def snap2 = wg.get()
assert(snap1 == "n\n1\n")
assert(snap2 == "n\n1\n2\n")

# ---- write_file ----

def out_path = "./frost_csv_write_test.csv"
def wf = csv.write_file(out_path, {headers: ["col1", "col2"]})
wf.row(["hello", "world"])
wf.row(["foo", "bar"])
wf.flush()

def written = csv.read_file(out_path, {headers: true})
assert(len(written) == 2)
assert(written[0].col1 == "hello")
assert(written[1].col2 == "bar")

# ---- error: map row without headers defined ----

def wne = csv.write_str()
def map_err = try_call(fn -> wne.row({a: "1"}))
assert(map_err.ok == false)
assert(contains(map_err.error, "headers"))

# ---- error: map row missing key ----

def wmk = csv.write_str({headers: ["x", "y"]})
def missing_key = try_call(fn -> wmk.row({x: "1"}))
assert(missing_key.ok == false)
assert(contains(missing_key.error, "missing key"))

# ---- error: row with non-primitive value ----

def wnp = csv.write_str({headers: ["val"]})
def non_prim = try_call(fn -> wnp.row([[1, 2, 3]]))
assert(non_prim.ok == false)
assert(contains(non_prim.error, "primitives"))

# ---- error: row wrong type ----

def wrt = csv.write_str()
def wrong_row = try_call(fn -> wrt.row("not an array"))
assert(wrong_row.ok == false)
