export def encoding = {
    name: 'encoding',
    title: 'Encoding',
    module_path: 'std.encoding',
    import_as: 'enc',
    description: [
        'Number formatting, byte-level string manipulation, and common encoding schemes (hex, Base64, URL percent-encoding).',
    ],
    entries: [
        {
            name: 'fmt_int',
            signatures: ['fmt_int(number, base)'],
            description: [
                'Returns a lowercase string representation of `number` in the given `base`. `base` must be in the range [2, 36].',
            ],
            params: [
                { name: 'number', desc: 'The number to format' },
                { name: 'base', desc: 'The numeric base (2-36)' },
            ],
            examples: [
                { code: "enc.fmt_int(255, 16)", result: 'ff' },
                { code: "enc.fmt_int(10, 2)", result: '1010' },
            ],
            see_also: ['std.encoding.parse_int'],
        },
        {
            name: 'parse_int',
            signatures: ['parse_int(string, base)'],
            description: [
                'Parses `string` as an integer in the given `base` and returns an Int. `base` must be in the range [2, 36].',
                'Produces an error if the string is not a valid integer in that base, or if the value is out of Int range.',
            ],
            params: [
                { name: 'string', desc: 'The string to parse' },
                { name: 'base', desc: 'The numeric base (2-36)' },
            ],
            examples: [
                { code: "enc.parse_int('ff', 16)", result: '255' },
                { code: "enc.parse_int('1010', 2)", result: '10' },
            ],
            see_also: ['std.encoding.fmt_int'],
        },
        {
            name: 'to_bytes',
            signatures: ['to_bytes(s)'],
            description: [
                'Returns an array of Int values representing the raw byte values (0-255) of each character in `s`.',
            ],
            examples: [
                { code: "enc.to_bytes('ABC')", result: '[65, 66, 67]' },
            ],
            see_also: ['std.encoding.from_bytes'],
        },
        {
            name: 'from_bytes',
            signatures: ['from_bytes(arr)'],
            description: [
                'Converts an array of Int values in the range [0, 255] to a string.',
                'Produces an error if any element is not an Int or is out of range.',
            ],
            examples: [
                { code: "enc.from_bytes([72, 105])", result: 'Hi' },
            ],
            see_also: ['std.encoding.to_bytes'],
        },
    ],
    children: {
        hex: {
            name: 'hex',
            description: ['Hexadecimal encoding and decoding.'],
            entries: [
                {
                    name: 'encode',
                    signatures: ['hex.encode(s)'],
                    description: [
                        'Encodes `s` as a lowercase hexadecimal string. Each byte becomes two hex characters.',
                    ],
                    examples: [
                        { code: "enc.hex.encode('Hi')", result: '4869' },
                    ],
                    see_also: ['std.encoding.hex.decode'],
                },
                {
                    name: 'decode',
                    signatures: ['hex.decode(s)'],
                    description: [
                        'Decodes a hexadecimal string and returns the raw bytes as a string. Input length must be even. Produces an error on invalid input.',
                        'The result is a raw binary string that may contain non-printable bytes. Printing such strings directly may produce unexpected terminal output.',
                    ],
                    examples: [
                        { code: "enc.hex.decode('4869')", result: 'Hi' },
                    ],
                    see_also: ['std.encoding.hex.encode'],
                },
            ],
        },
        b64: {
            name: 'b64',
            description: ['Base64 encoding and decoding (RFC 4648).'],
            entries: [
                {
                    name: 'encode',
                    signatures: ['b64.encode(s)'],
                    description: [
                        'Encodes `s` using standard Base64 (RFC 4648) and returns the result as a string.',
                    ],
                    examples: [
                        { code: "enc.b64.encode('Hello')", result: 'SGVsbG8=' },
                    ],
                    see_also: ['std.encoding.b64.decode'],
                },
                {
                    name: 'decode',
                    signatures: ['b64.decode(s)'],
                    description: [
                        'Decodes a standard Base64 (RFC 4648) string and returns the raw bytes as a string.',
                        'Produces an error on invalid input.',
                    ],
                    examples: [
                        { code: "enc.b64.decode('SGVsbG8=')", result: 'Hello' },
                    ],
                    see_also: ['std.encoding.b64.encode'],
                },
                {
                    name: 'urlencode',
                    signatures: ['b64.urlencode(s)'],
                    description: [
                        'Encodes `s` using URL-safe Base64 and returns the result as a string.',
                    ],
                    see_also: ['std.encoding.b64.urldecode'],
                },
                {
                    name: 'urldecode',
                    signatures: ['b64.urldecode(s)'],
                    description: [
                        'Decodes a URL-safe Base64 string and returns the raw bytes as a string.',
                        'Produces an error on invalid input.',
                    ],
                    see_also: ['std.encoding.b64.urlencode'],
                },
            ],
        },
        url: {
            name: 'url',
            description: ['URL percent-encoding (RFC 3986).'],
            entries: [
                {
                    name: 'encode',
                    signatures: ['url.encode(s)'],
                    description: [
                        'Percent-encodes `s` per RFC 3986. Unreserved characters (A-Z, a-z, 0-9, `-`, `.`, `_`, `~`) are not encoded.',
                    ],
                    examples: [
                        { code: "enc.url.encode('hello world')", result: 'hello%20world' },
                    ],
                    see_also: ['std.encoding.url.decode'],
                },
                {
                    name: 'decode',
                    signatures: ['url.decode(s)'],
                    description: [
                        'Decodes a percent-encoded string.',
                        'Produces an error on invalid input (e.g. `%GG`, truncated `%`).',
                    ],
                    examples: [
                        { code: "enc.url.decode('hello%20world')", result: 'hello world' },
                    ],
                    see_also: ['std.encoding.url.encode'],
                },
            ],
        },
    },
}
